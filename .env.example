# Docker Compose environment variables example
# Copy to .env and adjust as needed. DO NOT commit .env containing real secrets.

# ---------- SQL Server (local dev) ----------
# Required by mcr.microsoft.com/mssql/server image
ACCEPT_EULA=Y
# Use a strong SA_PASSWORD that meets SQL Server complexity rules
SA_PASSWORD=YourStrong!Passw0rd

# ---------- ASP.NET Core / App configuration ----------
ASPNETCORE_ENVIRONMENT=Development

# Database connection string used by the API (override for containers)
# Example: Server=sqlserver;Database=ProjectTemplate2024;User=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=True;
Database__ConnectionString=Server=sqlserver;Database=ProjectTemplate2024;User=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=True;

# Blob storage (optional) - secret for connection, and public URL for generated links
Database__BlobConnectionString=
Database__BlobUrl=

# ---------- JWT / Identity (must be set) ----------
# Minimal: JwtSettings__Secret must be a long random secret (recommended >= 32 bytes)
JwtSettings__Secret=ReplaceWithLongRandomSecretHere
JwtSettings__Issuer=ProjectTemplate2024
JwtSettings__Audience=ProjectTemplate2024
JwtSettings__ExpiryMinutes=60

# ---------- Mail / SMTP (if you want emails to work) ----------
# MailSettings section is bound to MailSettings in code (see EmailSettings.cs)
MailSettings__Host=
MailSettings__Port=2525
MailSettings__From=notifications@example.com
MailSettings__DisplayName=ProjectTemplate2024
MailSettings__Username=
MailSettings__Password=

# ---------- External integrations ----------
# Google OAuth client id (if used)
Google__ClientId=

# Client app (used for CORS / confirmation links)
ClientApp__Url=http://localhost:5173

# ---------- Notes ----------
# 1) This file is an example for local/docker development. Copy it to `.env` and fill secrets:
#    PowerShell: Copy-Item .env.docker.example .env
#    Bash: cp .env.docker.example .env
# 2) Never commit a real `.env` with production secrets. For CI/prod use a secret manager
#    (Azure Key Vault, GitHub Actions secrets, Docker/Kubernetes secrets, etc.).
# 3) Ensure `SA_PASSWORD` meets SQL Server complexity rules when starting the SQL container.
# 4) The API reads configuration using the section names (e.g. `JwtSettings`, `Database`, `MailSettings`).
